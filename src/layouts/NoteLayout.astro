---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const { title, description, category, readingTime, date, oneLine } = frontmatter;
---
<BaseLayout title={`${title} — डॉ. गिरीश कुलकर्णी`} description={description}>
  <article class="article">
    <div class="wrap">
      <a class="backlink" href="/notes/">← सर्व नोट्स</a>
      <header class="article-head" style="max-width:var(--measure);margin-inline:auto">
        <div class="meta">
          <span class="cat">{category}</span>
          <span>वाचायला वेळ: {readingTime}</span>
          {date && <span>{date}</span>}
        </div>
        <h1>{title}</h1>
        {description && <p class="desc">{description}</p>}
      </header>
      <div class="prose">
        <slot />
      </div>
      {oneLine && (
        <div class="oneline">
          <div class="lab">एका वाक्यात</div>
          <p>{oneLine}</p>
        </div>
      )}
      <div class="article-foot">
        <a class="backlink" href="/notes/">← आणखी नोट्स वाचा</a>
        <span class="sign">— गिरीश</span>
      </div>
    </div>
  </article>
</BaseLayout>
