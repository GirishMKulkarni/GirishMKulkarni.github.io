---
import { socials } from '../data/site.js';
const year = new Date().getFullYear();
---
<footer class="site-foot">
  <div class="wrap">
    <div class="foot-top">
      <div>
        <a class="brand" href="/"><span class="mark">GK</span> डॉ. गिरीश कुलकर्णी</a>
        <p class="tag">AI समजून घेण्याचा एक प्रयत्न — गणित, संशोधन आणि प्रत्यक्ष अनुभवातून, सोप्या मराठीत.</p>
      </div>
      <nav class="foot-links" aria-label="तळटीप दुवे">
        <a href="/notes/">AI नोट्स</a>
        <a href="/workshops/">वर्कशॉप्स</a>
        <a href="/experiments/">प्रयोग</a>
        <a href={socials.github} target="_blank" rel="noopener">GitHub</a>
        <a href={socials.vidhan} target="_blank" rel="noopener">Vidhan.AI</a>
        <a href={`mailto:${socials.email}`}>ईमेल</a>
      </nav>
    </div>
    <div class="foot-bottom">
      <span>© {year} डॉ. गिरीश कुलकर्णी</span>
      <span>Pune, India · {socials.email}</span>
    </div>
  </div>
</footer>
