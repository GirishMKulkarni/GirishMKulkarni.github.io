---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ideas = [
  { t: 'ChatGPT ला M.Sc. पातळीचं गणित सोडवता येतं का?', d: '२० निवडक प्रश्न देऊन, प्रत्येक उत्तर तपासून गुण देतो. निकाल इथे प्रामाणिकपणे मांडेन.' },
  { t: 'मराठी vs इंग्रजी — प्रश्नाच्या भाषेने उत्तर बदलतं का?', d: 'तेच ५० प्रश्न दोन्ही भाषांत विचारून उत्तरांची तुलना.' },
  { t: 'AI किती वेळा खोटे कायदेशीर संदर्भ देतं?', d: 'Vidhan.AI वरील अनुभवातून — hallucination चं प्रमाण मोजतो.' },
  { t: 'फोटोवरून झाड ओळखता येतं का?', d: 'Gemini / ChatGPT ला स्थानिक झाडांचे फोटो देऊन अचूकता तपासतो.' },
];
---
<BaseLayout
  title="प्रयोग — AI तपासून बघूया — डॉ. गिरीश कुलकर्णी"
  description="दाव्यांवर विश्वास ठेवण्याऐवजी AI तपासून बघणारे छोटे प्रयोग — पद्धत आणि निकालांसह."
>
  <section class="section">
    <div class="wrap">
      <div class="section-head narrow">
        <span class="kicker">प्रयोग</span>
        <h2>“AI शक्तिशाली आहे” — पण खरंच किती?</h2>
        <p>दाव्यांवर विश्वास ठेवण्याऐवजी, प्रयोग करून बघूया. प्रत्येक प्रयोगाची पद्धत आणि निकाल इथे मोकळेपणाने मांडेन — चांगले असोत वा वाईट. पहिले निकाल लवकरच.</p>
      </div>
      <div class="grid c2">
        {ideas.map((e) => (
          <div class="exp reveal">
            <span class="status">निकाल लवकरच</span>
            <h3>{e.t}</h3>
            <p>{e.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
